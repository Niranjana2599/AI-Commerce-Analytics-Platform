  "panels": [
    {"datasource": {"uid": "prometheus"}, "fieldConfig": {"defaults": {"unit": "reqps"}}, "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0}, "id": 1, "targets": [{"expr": "sum(rate(http_requests_total[5m]))", "refId": "A"}], "title": "HTTP requests / second", "type": "timeseries"},
    {"datasource": {"uid": "prometheus"}, "fieldConfig": {"defaults": {"unit": "s"}}, "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}, "id": 2, "targets": [{"expr": "histogram_quantile(0.95, sum by (le, endpoint) (rate(http_request_duration_seconds_bucket[5m])))", "legendFormat": "{{endpoint}}", "refId": "A"}], "title": "p95 response time by endpoint", "type": "timeseries"},
    {"datasource": {"uid": "prometheus"}, "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8}, "id": 3, "targets": [{"expr": "sum by (status_code) (rate(http_requests_total[5m]))", "legendFormat": "{{status_code}}", "refId": "A"}], "title": "Response status codes", "type": "timeseries"},
    {"datasource": {"uid": "prometheus"}, "fieldConfig": {"defaults": {"unit": "percentunit", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 0.05}]}}}, "gridPos": {"h": 8, "w": 6, "x": 12, "y": 8}, "id": 4, "options": {"reduceOptions": {"calcs": ["lastNotNull"]}}, "targets": [{"expr": "sum(rate(http_errors_total[5m])) / clamp_min(sum(rate(http_requests_total[5m])), 1)", "refId": "A"}], "title": "5xx error rate", "type": "gauge"},
    {"datasource": {"uid": "prometheus"}, "fieldConfig": {"defaults": {"decimals": 0}}, "gridPos": {"h": 8, "w": 6, "x": 18, "y": 8}, "id": 5, "options": {"reduceOptions": {"calcs": ["lastNotNull"]}}, "targets": [{"expr": "active_requests", "refId": "A"}], "title": "Active requests", "type": "stat"},
    {"datasource": {"uid": "prometheus"}, "fieldConfig": {"defaults": {"unit": "s"}}, "gridPos": {"h": 8, "w": 24, "x": 0, "y": 16}, "id": 6, "targets": [{"expr": "histogram_quantile(0.95, sum by (le, endpoint) (rate(http_request_duration_seconds_bucket[5m])))", "legendFormat": "{{endpoint}}", "refId": "A"}], "title": "Endpoint latency (p95)", "type": "bargauge"}
