    {"datasource": {"uid": "prometheus"}, "fieldConfig": {"defaults": {"unit": "short"}}, "gridPos": {"h": 8, "w": 8, "x": 16, "y": 0}, "id": 3, "options": {"reduceOptions": {"calcs": ["lastNotNull"]}}, "targets": [{"expr": "rate(rag_retrieved_documents_sum[5m]) / clamp_min(rate(rag_retrieved_documents_count[5m]), 1)", "refId": "A"}], "title": "Average retrieved documents", "type": "gauge"},
    {"datasource": {"uid": "prometheus"}, "fieldConfig": {"defaults": {"unit": "s"}}, "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8}, "id": 4, "targets": [{"expr": "histogram_quantile(0.95, sum by (le) (rate(rag_retriever_latency_seconds_bucket[5m])))", "refId": "A"}, {"expr": "histogram_quantile(0.95, sum by (le) (rate(rag_llm_latency_seconds_bucket[5m])))", "refId": "B"}, {"expr": "histogram_quantile(0.95, sum by (le) (rate(rag_latency_seconds_bucket[5m])))", "refId": "C"}], "title": "RAG latency (p95): retriever, LLM, total", "type": "timeseries"},
