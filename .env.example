# Host port exposed for FastAPI.
BACKEND_PORT=8000

# Host port exposed for Streamlit.
STREAMLIT_PORT=8501

# Host port exposed for the MLflow tracking UI.
MLFLOW_PORT=5000

# Run FastAPI with production-safe error responses.
APP_ENV=production

# Permit the browser-hosted Streamlit UI to call FastAPI when required.
CORS_ORIGINS=http://localhost:8501

# Docker Compose sets this automatically; retain it for documentation and overrides.
FASTAPI_BASE_URL=http://backend:8000/api/v1
