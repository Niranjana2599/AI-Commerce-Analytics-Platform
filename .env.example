# Host port exposed for FastAPI.
BACKEND_PORT=8000

# Host port exposed for Streamlit.
STREAMLIT_PORT=8501

# Host port exposed for the MLflow tracking UI.
MLFLOW_PORT=5000

# Host port exposed for the Prometheus monitoring UI.
PROMETHEUS_PORT=9090

# Grafana login. Change the password before deploying outside local development.
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Run FastAPI with production-safe error responses.
APP_ENV=production

# Permit the browser-hosted Streamlit UI to call FastAPI when required.
CORS_ORIGINS=http://localhost:8501

# Docker Compose sets this automatically; retain it for documentation and overrides.
FASTAPI_BASE_URL=http://backend:8000/api/v1

# Enable Ollama generation for RAG responses. Keep false to return retrieved context only.
RAG_LLM_ENABLED=false

# Local Ollama endpoint and model name used when generation is enabled.
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2

# LangSmith is optional. Copy this file to .env and set the API key locally;
# never commit the populated .env file.
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=AI-Commerce-Analytics-Platform
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# Render deployment: use a private, time-limited URL for a ZIP containing
# processed/master_df.parquet and models/. Set this secret in Render, not Git.
DEPLOY_ASSETS_DIR=/var/data
ASSET_BUNDLE_URL=
